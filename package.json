{
  "name": "meinberg-ict",
  "description": "Meinberg's IED Configuration Tool, powered by OpenSCD.",
  "license": "Apache-2.0",
  "author": "Axel Perales - Meinberg Funkuhren GmbH & Co. KG",
  "version": "0.0.0",
  "scripts": {
    "preinstall": "git submodule update --init --recursive && npm run update",
    "update": "git submodule foreach git pull origin gh-pages",
    "build": "rimraf dist && rollup -c rollup.config.js",
    "deploy": "npm run preinstall && npm run build && gh-pages -d dist",
    "deploy:nobuild": "gh-pages -d dist",
    "start:build": "web-dev-server --root-dir dist --app-index index.html --open",
    "start": "web-dev-server --node-resolve"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@open-wc/building-rollup": "^2.2.3",
    "@rollup/plugin-babel": "^5.3.1",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@web/dev-server": "^0.1.38",
    "@web/rollup-plugin-html": "^1.11.1",
    "@web/rollup-plugin-import-meta-assets": "^1.0.8",
    "babel-plugin-template-html-minifier": "^4.1.0",
    "gh-pages": "^4.0.0",
    "rimraf": "^3.0.2",
    "rollup": "^2.80.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-workbox": "^6.2.2"
  },
  "dependencies": {
    "@omicronenergy/oscd-background-editv1": "^0.0.7",
    "@omicronenergy/oscd-background-wizard-events": "^0.0.4",
    "@omicronenergy/oscd-editor-diff": "^0.0.2",
    "@omicronenergy/oscd-editor-source": "^0.0.5",
    "@omicronenergy/oscd-menu-commons": "^0.0.1",
    "@omicronenergy/oscd-shell": "^0.0.13",
    "@omicronenergy/oscd-ui": "^0.0.12",
    "@openscd/oscd-api": "^0.1.6",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "lit": "^3.3.2"
  }
}
